# ---- Copy to .env and fill in. Never commit .env. ----
# TEST BUILD: local email+password auth, no Azure. You run your own tunnel.

# App
PORT=8080
# Use 'development' for plain http://localhost testing (session cookie not marked
# Secure). Use 'production' when serving over HTTPS (e.g. behind your tunnel).
NODE_ENV=development
# Public base URL. For local testing: http://localhost:8080
BASE_URL=http://localhost:8080
# Random 64+ char string for signing session cookies: `openssl rand -hex 48`
SESSION_SECRET=CHANGE_ME_openssl_rand_hex_48

# ---- Auth ----
# Identity provider: local | entra
#   local: email+password sign-in (test build default)
#   entra: Entra ID (Azure AD) OIDC. Requires the ENTRA_* block below and an
#          app registration with Web redirect URI {BASE_URL}/auth/callback.
# WARNING: do not switch providers on a populated DB — user ids differ
# (generated UUID vs Entra oid). See README "Switching to Entra".
AUTH_PROVIDER=local

# Comma-separated allowlist permitted to sign in — one entry or several.
# Local: emails (first sign-in self-registers). Entra: emails and/or object
# ids (oid).
ALLOWED_USERS=you@example.com

# ---- Entra ID (only when AUTH_PROVIDER=entra) ----
#ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
#ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
#ENTRA_CLIENT_SECRET=CHANGE_ME_client_secret

# ---- Database ----
POSTGRES_USER=vault
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=vault
DATABASE_URL=postgres://vault:CHANGE_ME_db_password@db:5432/vault

# ---- LLM backend ----
# mode: direct | proxy
#   direct (recommended, Anthropic only): each user pastes their own API key in
#     the app; it is stored encrypted in their vault and the BROWSER calls
#     Anthropic directly. Plaintext never touches this server, and no key is
#     needed below.
#   proxy (legacy, supports openai): the server relays chat with the key below;
#     plaintext transits server RAM in-request.
# Default: direct if LLM_API_KEY is unset, otherwise proxy.
LLM_MODE=direct
LLM_MODEL=claude-sonnet-5
# Cheaper model for background tasks (compaction summaries, memory updates).
# Chat always uses LLM_MODEL. Unset to run everything on LLM_MODEL.
LLM_MODEL_UTILITY=claude-haiku-4-5
# provider + key: only used in proxy mode
LLM_PROVIDER=anthropic
#LLM_API_KEY=sk-...
# Optional override for OpenAI-compatible endpoints (proxy mode)
# LLM_BASE_URL=https://api.openai.com/v1

# ---- Compaction ----
COMPACT_TOKEN_THRESHOLD=8000
COMPACT_KEEP_RECENT=8
